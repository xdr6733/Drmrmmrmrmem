{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "SECRET_KEY": "@secret_key",
    "TELEGRAM_API_ID": "@telegram_api_id",
    "TELEGRAM_API_HASH": "@telegram_api_hash",
    "REDIRECT_BOT": "@redirect_bot"
  }
}
